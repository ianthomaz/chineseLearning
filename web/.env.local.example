# Se apagaste o .env.local, recria assim:
#   cp .env.local.example .env.local
#
# Token: o mesmo Bearer serve para API local (Docker) e para https://llm.webplace.cc
LLM_API_TOKEN=cola-o-token-do-servidor-da-api
#
# URL da API (opcional — se omitires, usa web/.env = http://127.0.0.1:28471).
# Escolhe UMA consoante o que tens a correr; não precisas de mudar código, só esta linha:
#
#   LLM_API_URL=http://127.0.0.1:28471
#   LLM_API_URL=https://llm.webplace.cc
#
# Tutor + POST /api/chat: precisas de Node (não basta export estático):
#   ./start.sh --local   ou   npm run deploy:local:with-api
# Só HTML estático: npm run deploy:local  ou  ./start.sh --webplace

# Opcional (ingest RAG com API em Docker):
# RAG_SOURCES_PATH=/caminho/dentro/do/container/rag_knowledge
