# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# PWA (generated on production build; path includes basePath when set)
public/**/sw.js
public/**/sw.js.map
public/**/workbox-*.js
public/**/workbox-*.js.map

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env: commit web/.env (defaults). Secrets only in .env.local (ignored).
.env.local
# Server deploy secrets (copy from deploy/server.env.example).
/deploy/server.env
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# Large vocabulary PDFs — tracked list in src/data/vocabulary-pdf-downloads.json; files live here and sync into public/downloads on prebuild/predev (see scripts/sync-pdf-downloads.sh). deploy-node rsync sends pdf-content/; excludes redundant public/downloads/*.pdf.
/pdf-content/*.pdf
/public/downloads/*.pdf

# typescript
*.tsbuildinfo
next-env.d.ts
