{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/parse-consolidado.mjs",
    "prebuild": "node scripts/parse-consolidado.mjs",
    "review-extras:locales": "node scripts/build-review-extras-md.mjs",
    "dev": "next dev --turbopack -p 34827",
    "build": "next build",
    "build:webplace": "NEXT_PUBLIC_BASE_PATH=/aulaChines NEXT_STATIC_EXPORT=1 next build",
    "build:server": "NEXT_PUBLIC_BASE_PATH=/aulaChines next build",
    "preview:webplace": "bash scripts/preview-webplace-local.sh",
    "deploy:webplace": "bash scripts/deploy-webplace.sh",
    "deploy:node": "bash scripts/deploy-node.sh",
    "deploy:local": "bash -c 'export DEPLOY_LOCAL_DIR=\"${DEPLOY_LOCAL_DIR:-/tmp/chineseLearning-webplace-out}\"; bash scripts/deploy-webplace.sh'",
    "check:llm": "bash scripts/check-llm-health.sh",
    "ingest:rag": "bash ../connectLLM/ingest-chinese-learning.sh",
    "start": "next start -p 34827",
    "start:server": "next start -H 127.0.0.1 -p ${PORT:-34827}",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.9",
    "pinyin-pro": "^3.28.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
