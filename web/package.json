{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/parse-consolidado.mjs && bash scripts/sync-pdf-downloads.sh && node scripts/build-vocabulary-pdf-manifest.mjs",
    "prebuild": "node scripts/parse-consolidado.mjs && bash scripts/sync-pdf-downloads.sh && node scripts/build-vocabulary-pdf-manifest.mjs",
    "prebuild:pdf": "bash scripts/sync-pdf-downloads.sh && node scripts/build-vocabulary-pdf-manifest.mjs",
    "review-extras:locales": "node scripts/build-review-extras-md.mjs",
    "dev": "NEXT_PUBLIC_BASE_PATH=/aulaChines next dev --turbopack -p 34827",
    "hot": "npm run dev",
    "dev:plain": "next dev --turbopack -p 34827",
    "build": "next build",
    "build:webplace": "npm run prebuild && NEXT_PUBLIC_BASE_PATH=/aulaChines NEXT_STATIC_EXPORT=1 next build",
    "build:server": "npm run prebuild:pdf && NEXT_PUBLIC_BASE_PATH=/aulaChines next build",
    "preview:webplace": "bash scripts/preview-webplace-local.sh",
    "deploy:webplace": "bash scripts/deploy-webplace.sh",
    "deploy:node": "bash scripts/deploy-node.sh",
    "deploy:node:lite": "env DEPLOY_NODE_SKIP_CI=1 bash scripts/deploy-node.sh",
    "remote:handshake": "bash scripts/remote-prod-handshake.sh",
    "deploy:local": "bash -c 'export DEPLOY_LOCAL_DIR=\"${DEPLOY_LOCAL_DIR:-/tmp/chineseLearning-webplace-out}\"; bash scripts/deploy-webplace.sh'",
    "deploy:local:static": "bash -c 'export DEPLOY_LOCAL_DIR=\"${DEPLOY_LOCAL_DIR:-/tmp/chineseLearning-webplace-out}\"; bash scripts/deploy-webplace.sh'",
    "serve:local": "bash scripts/serve-local-static.sh",
    "deploy:local:live": "bash scripts/deploy-local-live.sh",
    "deploy:local:with-api": "bash scripts/deploy-local-live.sh",
    "check:llm": "bash scripts/check-llm-health.sh",
    "ingest:rag": "bash ../connectLLM/ingest-chinese-learning.sh",
    "start": "PORT=34827 node scripts/start-server-stripped.mjs",
    "start:server": "node scripts/start-server-stripped.mjs",
    "lint": "next lint",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "hanzi-writer": "^3.7.3",
    "next": "^15.3.9",
    "pdfjs-dist": "^4.8.69",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.2.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.9",
    "pinyin-pro": "^3.28.0",
    "pngjs": "^7.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
