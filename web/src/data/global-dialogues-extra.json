            "es": "¿De qué país eres?"
          }
        },
        {
          "speaker": "B",
          "hanzi": "我是巴西人。",
          "pinyin": "Wǒ shì Bāxī rén.",
          "translation": {
            "pt": "Sou brasileiro.",
            "en": "I'm Brazilian.",
            "es": "Soy brasileño."
          }
        },
        {
          "speaker": "A",
          "hanzi": "欢迎来中国！",
          "pinyin": "Huānyíng lái Zhōngguó!",
          "translation": {
            "pt": "Bem-vindo à China!",
            "en": "Welcome to China!",
            "es": "¡Bienvenido a China!"
          }
        }
      ]
    },
    {
      "id": "languageSpeak",
      "categoryId": 5,
      "lines": [
