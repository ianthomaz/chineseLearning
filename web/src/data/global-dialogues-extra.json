{
  "sections": [
    {
      "id": "numbersPhone",
      "categoryId": 1,
      "lines": [
        {
          "speaker": "A",
          "hanzi": "你的电话是多少？",
          "pinyin": "Nǐ de diànhuà shì duōshǎo?",
          "translation": {
            "pt": "Qual é o teu número de telefone?",
            "en": "What is your phone number?",
            "es": "¿Cuál es tu teléfono?"
          }
        },
        {
          "speaker": "B",
          "hanzi": "我的电话是一三八零零一二三四五。",
          "pinyin": "Wǒ de diànhuà shì yī sān bā líng líng yī èr sān sì wǔ.",
          "translation": {
            "pt": "O meu número é 1380012345.",
            "en": "My number is 1380012345.",
            "es": "Mi número es 1380012345."
          }
        },
        {
          "speaker": "A",
          "hanzi": "谢谢，我记一下。",
          "pinyin": "Xièxie, wǒ jì yīxià.",
          "translation": {
            "pt": "Obrigado, vou anotar.",
            "en": "Thanks, I'll write it down.",
            "es": "Gracias, lo apunto."
          }
        }
      ]
    },
    {
      "id": "numbersPrice",
      "categoryId": 1,
      "lines": [
        {
          "speaker": "A",
          "hanzi": "这个多少钱？",
          "pinyin": "Zhège duōshao qián?",
          "translation": {
            "pt": "Quanto custa isto?",
            "en": "How much is this?",
            "es": "¿Cuánto cuesta esto?"
          }
        },
        {
          "speaker": "B",
          "hanzi": "二十五块。",
          "pinyin": "Èrshíwǔ kuài.",
          "translation": {
            "pt": "Vinte e cinco yuan.",
            "en": "Twenty-five yuan.",
            "es": "Veinticinco yuan."
          }
        },
        {
          "speaker": "A",
          "hanzi": "太贵了，二十块可以吗？",
          "pinyin": "Tài guì le, èrshí kuài kěyǐ ma?",
          "translation": {
            "pt": "Muito caro, vinte yuan serve?",
            "en": "Too expensive, is twenty okay?",
            "es": "Muy caro, ¿veinte vale?"
          }
        },
        {
          "speaker": "B",
          "hanzi": "好吧。",
          "pinyin": "Hǎo ba.",
          "translation": {
            "pt": "Está bem.",
            "en": "Okay.",
            "es": "Vale."
          }
        }
      ]
    },
    {
      "id": "numbersAge",
      "categoryId": 1,
      "lines": [
        {
          "speaker": "A",
          "hanzi": "你今年多大？",
          "pinyin": "Nǐ jīnnián duō dà?",
          "translation": {
            "pt": "Quantos anos tens este ano?",
            "en": "How old are you this year?",
            "es": "¿Cuántos años tienes este año?"
          }
        },
        {
          "speaker": "B",
          "hanzi": "我今年二十二岁。你呢？",
          "pinyin": "Wǒ jīnnián èrshí'èr suì. Nǐ ne?",
          "translation": {
            "pt": "Tenho vinte e dois. E tu?",
            "en": "I'm twenty-two. And you?",
            "es": "Tengo veintidós. ¿Y tú?"
          }
        },
        {
          "speaker": "A",
          "hanzi": "我二十一岁。",
          "pinyin": "Wǒ èrshíyī suì.",
          "translation": {
            "pt": "Tenho vinte e um.",
            "en": "I'm twenty-one.",
            "es": "Tengo veintiuno."
          }
        }
      ]
    },
    {
      "id": "cafeBill",
      "categoryId": 2,
      "lines": [
        {
          "speaker": "A",
          "hanzi": "服务员，买单！",
          "pinyin": "Fúwùyuán, mǎidān!",
          "translation": {
            "pt": "Empregado, a conta por favor!",
            "en": "Waiter, the check please!",
            "es": "¡Camarero, la cuenta!"
          }
        },
        {
          "speaker": "B",
          "hanzi": "一共三十五块。",
          "pinyin": "Yīgòng sānshíwǔ kuài.",
          "translation": {
            "pt": "São trinta e cinco yuan no total.",
            "en": "Thirty-five yuan in total.",
            "es": "Treinta y cinco yuan en total."
          }
        },
        {
          "speaker": "A",
          "hanzi": "给你四十块，不用找了。",
          "pinyin": "Gěi nǐ sìshí kuài, bùyòng zhǎo le.",
          "translation": {
            "pt": "Aqui tens quarenta, fica o troco.",
            "en": "Here's forty, keep the change.",
            "es": "Te doy cuarenta, quédate con el cambio."
          }
        }
      ]
    },
    {
      "id": "nationalityIntro",
      "categoryId": 5,
      "lines": [
        {
          "speaker": "A",
          "hanzi": "你是哪国人？",
