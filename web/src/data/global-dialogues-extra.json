          "speaker": "B",
          "hanzi": "对，很美。",
          "pinyin": "Duì, hěn měi.",
          "translation": {
            "pt": "Sim, muito bonita.",
            "en": "Yes, very beautiful.",
            "es": "Sí, muy bonita."
          }
        }
      ]
    },
    {
