    "dialogos": {
      "apresentando-familia": {
        "lines": [
          {"id": "af-1", "char": 1, "nameId": "char-mario", "hanzi": "王先生，你好！这是我弟弟。", "pinyin": "Wáng xiānsheng, nǐ hǎo! Zhè shì wǒ dìdi."},
          {"id": "af-2", "char": 2, "nameId": "char-wang", "hanzi": "你好！你弟弟叫什么名字？", "pinyin": "Nǐ hǎo! Nǐ dìdi jiào shénme míngzi?"},
          {"id": "af-3", "char": 3, "nameId": "char-pedro", "hanzi": "您好！我叫大卫。认识您很高兴。", "pinyin": "Nín hǎo! Wǒ jiào Dàwèi. Rènshi nín hěn gāoxìng."},
          {"id": "af-4", "char": 2, "nameId": "char-wang", "hanzi": "认识你我也很高兴。", "pinyin": "Rènshi nǐ wǒ yě hěn gāoxìng."}
        ]
      },
      "planos-dia": {
        "lines": [
          {"id": "pd-l1", "char": 1, "nameId": "char-anna", "hanzi": "你今天几点起床？", "pinyin": "Nǐ jīntiān jǐ diǎn qǐchuáng?"},
          {"id": "pd-l2", "char": 2, "nameId": "char-li", "hanzi": "我早上七点起床。你呢？", "pinyin": "Wǒ zǎoshang qī diǎn qǐchuáng. Nǐ ne?"},
          {"id": "pd-l3", "char": 1, "nameId": "char-anna", "hanzi": "我八点起床。你今天做什么？", "pinyin": "Wǒ bā diǎn qǐchuáng. Nǐ jīntiān zuò shénme?"},
          {"id": "pd-l4", "char": 2, "nameId": "char-li", "hanzi": "我下午去书店买书。", "pinyin": "Wǒ xiàwǔ qù shūdiàn mǎi shū."}
        ]
      },
      "supermercado": {
        "lines": [
          {"id": "sm-1", "char": 1, "nameId": "char-cliente", "hanzi": "请问，苹果多少钱一斤？", "pinyin": "Qǐngwèn, píngguǒ duōshǎo qián yī jīn?"},
          {"id": "sm-2", "char": 2, "nameId": "char-vendedor", "hanzi": "五块钱一斤。", "pinyin": "Wǔ kuài qián yī jīn."},
          {"id": "sm-3", "char": 1, "nameId": "char-cliente", "hanzi": "太贵了！便宜一点儿吧。", "pinyin": "Tài guì le! Piányi yīdiǎnr ba."},
          {"id": "sm-4", "char": 2, "nameId": "char-vendedor", "hanzi": "四块五，怎么样？", "pinyin": "Sì kuài wǔ, zěnmeyàng?"}
        ]
      },
      "escola": {
        "lines": [
          {"id": "es-1", "char": 1, "nameId": "char-prof", "hanzi": "同学们好！今天我们学习第三课。", "pinyin": "Tóngxuémen hǎo! Jīntiān wǒmen xuéxí dì sān kè."},
          {"id": "es-2", "char": 2, "nameId": "char-aluno1", "hanzi": "老师，我不懂这个汉字。", "pinyin": "Lǎoshī, wǒ bù dǒng zhège hànzì."},
          {"id": "es-3", "char": 3, "nameId": "char-aluno2", "hanzi": "我也觉得很难。", "pinyin": "Wǒ yě juéde hěn nán."},
          {"id": "es-4", "char": 1, "nameId": "char-prof", "hanzi": "没关系，多写多看。跟我读：'学习'。", "pinyin": "Méi guānxi, duō xiě duō kàn. Gēn wǒ dú: 'xuéxí'."}
        ]
      },
      "parque": {
        "lines": [
          {"id": "pq-1", "char": 1, "nameId": "char-zhang", "hanzi": "这里的风景真漂亮！", "pinyin": "Zhèlǐ de fēngjǐng zhēn piàoliang!"},
          {"id": "pq-2", "char": 2, "nameId": "char-wang2", "hanzi": "是的。你喜欢什么运动？", "pinyin": "Shì de. Nǐ xǐhuān shénme yùndòng?"},
          {"id": "pq-3", "char": 1, "nameId": "char-zhang", "hanzi": "我喜欢跑步和游泳。你呢？", "pinyin": "Wǒ xǐhuān pǎobù hé yóuyǒng. Nǐ ne?"},
          {"id": "pq-4", "char": 2, "nameId": "char-wang2", "hanzi": "我喜欢打太极拳。", "pinyin": "Wǒ xǐhuān dǎ tàijíquán."}
        ]
      }
    }
